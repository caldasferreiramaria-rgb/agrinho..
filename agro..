    <div class="logo-area">
      <i class="fas fa-tractor logo-icon"></i>
      <div class="logo-text">
        <h1>CPT Digital</h1>
        <span>Automação · IA · IoT no campo</span>
      </div>
    </div>
    <nav>
      <ul>
