    <div style="margin-top:18px;">
      <i class="fab fa-facebook fa-lg" style="margin:0 10px;"></i>
      <i class="fab fa-instagram fa-lg" style="margin:0 10px;"></i>
      <i class="fab fa-youtube fa-lg" style="margin:0 10px;"></i>
    </div>
  </div>
</footer>

<script>
  (function(){
    // ---------- JOGO DA MEMÓRIA (6 pares = 12 cartas) ----------
    const board = document.getElementById('gameBoard');
    const tentativasSpan = document.getElementById('tentativas');
    const paresFeitosSpan = document.getElementById('pares-feitos');
    const msgJogo = document.getElementById('mensagemJogo');
    const resetBtn = document.getElementById('resetGame');

    // ícones relacionados ao tema (fontawesome)
    const icons = [
      'fa-microchip',        // IoT / chip
      'fa-brain',            // IA
      'fa-robot',            // Automação
      'fa-wifi',             // Conectividade
      'fa-satellite',        // Sensoriamento remoto
      'fa-tractor'           // Máquina inteligente
    ];

    let cards = [];
    let flippedCards = [];
    let matchedPairs = 0;
    let tentativas = 0;
    let lockBoard = false;
    let gameFinished = false;

    function initGame() {
      let deck = [];
      icons.forEach((icon, index) => {
        deck.push({ id: index*2, icon: icon, matched: false, flipped: false });
        deck.push({ id: index*2+1, icon: icon, matched: false, flipped: false });
      });
      deck = shuffleArray(deck);
      cards = deck;
      flippedCards = [];
      matchedPairs = 0;
      tentativas = 0;
      lockBoard = false;
      gameFinished = false;
      updateStats();
      msgJogo.textContent = 'Clique nas cartas para encontrar os pares!';
      renderBoard();
    }

    function shuffleArray(arr) {
      for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
    }

    function renderBoard() {
      board.innerHTML = '';
      cards.forEach((card, idx) => {
        const cardDiv = document.createElement('div');
        cardDiv.className = 'card-game';
        if (card.matched) {
          cardDiv.classList.add('matched');
        } else if (card.flipped) {
          cardDiv.classList.add('flipped');
        }
        
        if (card.flipped || card.matched) {
          cardDiv.innerHTML = `<i class="fas ${card.icon}"></i>`;
        } else {
          cardDiv.innerHTML = `<i class="fas fa-question"></i>`;
        }
        cardDiv.dataset.index = idx;
        cardDiv.addEventListener('click', () => onCardClick(idx));
        board.appendChild(cardDiv);
      });
    }

    function onCardClick(index) {
      // Impede ações se o jogo estiver bloqueado, finalizado, ou se a carta já estiver combinada/virada
      if (lockBoard || gameFinished) return;
      const card = cards[index];
      if (card.matched) return;
      if (card.flipped) return;

      // Vira a carta
      card.flipped = true;
      flippedCards.push(index);
      renderBoard();

      // Verifica se duas cartas estão viradas
      if (flippedCards.length === 2) {
        tentativas++;
        updateStats();
        lockBoard = true;
        
        const idxA = flippedCards[0];
        const idxB = flippedCards[1];
        const cardA = cards[idxA];
        const cardB = cards[idxB];

        if (cardA.icon === cardB.icon) {
          // Par correto
          cardA.matched = true;
          cardB.matched = true;
          // Mantém flipped true para exibir o ícone
          matchedPairs++;
          updateStats();
          flippedCards = [];
          lockBoard = false;
          renderBoard();
          
          if (matchedPairs === icons.length) {
            gameFinished = true;
            msgJogo.textContent = '🎉 Parabéns! Você digitalizou o campo com sucesso!';
          } else {
            msgJogo.textContent = '✅ Par encontrado! Continue!';
          }
        } else {
          // Errou: após um tempo, desvira as cartas
          msgJogo.textContent = '❌ Tente novamente...';
          setTimeout(() => {
            // Verifica se as cartas ainda não foram combinadas por algum outro evento (segurança)
            if (!cards[idxA].matched && !cards[idxB].matched) {
                cards[idxA].flipped = false;
                cards[idxB].flipped = false;
            }
            flippedCards = [];
            lockBoard = false;
            renderBoard();
            if (!gameFinished && matchedPairs !== icons.length) {
                msgJogo.textContent = 'Escolha outro par.';
            }
          }, 800);
        }
      } else {
        msgJogo.textContent = 'Escolha a segunda carta...';
      }
    }

    function updateStats() {
      tentativasSpan.textContent = tentativas;
      paresFeitosSpan.textContent = matchedPairs + '/' + icons.length;
    }

    resetBtn.addEventListener('click', () => {
      initGame();
    });

    initGame();
  })();
</script>

<!-- Smooth scroll para links internos -->
<script>
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      const href = this.getAttribute('href');
      if (href === "#" || href === "") return;
      const target = document.querySelector(href);
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });
</script>
</body>
