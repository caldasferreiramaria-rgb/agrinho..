<main class="container">
  <!-- HISTÓRIA EM QUADRINHOS -->
  <section id="hq">
    <div class="section-title">
      <i class="fas fa-pencil-ruler"></i>
      <span>História em Quadrinhos · CPT no futuro do agro</span>
    </div>
    <div class="comic-strip">
      <div class="comic-panels">
        <div class="panel">
          <i class="fas fa-cloud-upload-alt"></i>
          <div class="balao"><strong>Painel 1:</strong> “Precisamos irrigar melhor e gastar menos água.” — diz o produtor.</div>
        </div>
