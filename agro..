<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CPT Digital · Agro 4.0 · IA, IoT e Automação</title>
  <!-- Fontes e ícones -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: #f5f9f0;
      color: #1e2e1c;
      line-height: 1.5;
      scroll-behavior: smooth;
    }

    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* header */
    header {
      background: linear-gradient(145deg, #0a3d1f 0%, #1a5e32 100%);
      color: white;
      padding: 20px 0;
      box-shadow: 0 8px 20px rgba(0,20,0,0.15);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-flex {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
    }

    .logo-area {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .logo-icon {
      font-size: 2.8rem;
      color: #c3e6a5;
    }

    .logo-text h1 {
      font-weight: 700;
      font-size: 1.9rem;
      letter-spacing: -0.5px;
    }

    .logo-text span {
      font-weight: 400;
      font-size: 1rem;
      opacity: 0.9;
      display: block;
    }

    nav ul {
      display: flex;
      gap: 28px;
      list-style: none;
    }

    nav ul li a {
      color: white;
      text-decoration: none;
      font-weight: 500;
      padding: 8px 4px;
      border-bottom: 2px solid transparent;
      transition: 0.2s;
      font-size: 1.05rem;
    }

    nav ul li a:hover {
      border-bottom-color: #c3e6a5;
      color: #e2ffce;
    }

    .btn-jogo {
      background: #f4b942;
      color: #1e3a1e;
      padding: 10px 20px;
      border-radius: 40px;
      font-weight: 700;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
      border: none;
      transition: 0.2s;
    }

    .btn-jogo:hover {
      background: #ffcf6e;
      transform: scale(1.02);
      border-bottom: none;
    }

    /* hero */
    .hero {
      background: url('data:image/svg+xml;utf8,<svg width="100%" height="100%" viewBox="0 0 1200 300" xmlns="http://www.w3.org/2000/svg"><rect width="1200" height="300" fill="%23224d2a" /><path d="M0 200 L200 120 L400 220 L600 100 L800 180 L1000 90 L1200 160 L1200 300 L0 300 Z" fill="%23387a3c" opacity="0.6"/><circle cx="150" cy="60" r="18" fill="%23f4b942"/><circle cx="900" cy="80" r="30" fill="%2363c06b" opacity="0.5"/></svg>') no-repeat center/cover;
      padding: 70px 0 80px;
      color: white;
      border-bottom: 6px solid #c3e6a5;
    }

    .hero h2 {
      font-size: 3rem;
      font-weight: 700;
      max-width: 800px;
      text-shadow: 2px 2px 8px rgba(0,20,0,0.4);
    }

    .hero p {
      font-size: 1.3rem;
      margin: 20px 0 30px;
      max-width: 650px;
      opacity: 0.95;
    }

    .badge-cpt {
      background: #f4b942;
      color: #1e3a1e;
      display: inline-block;
      padding: 8px 18px;
      border-radius: 30px;
      font-weight: 700;
      margin-bottom: 15px;
    }

    /* sections */
    section {
      padding: 60px 0;
    }

    .section-title {
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 20px;
      color: #0a3d1f;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .section-title i {
      font-size: 2.2rem;
      color: #2a7a3e;
    }

    .grid-2col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }

    /* Cards e info */
    .info-card {
      background: white;
      border-radius: 24px;
      padding: 30px;
      box-shadow: 0 10px 25px rgba(0,20,0,0.05);
      border: 1px solid #d9ebc5;
    }

    .video-container {
      position: relative;
      padding-bottom: 56.25%;
      height: 0;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

    .video-container iframe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }

    /* HQ */
    .comic-strip {
      background: #eef6e4;
      border-radius: 28px;
      padding: 30px 25px;
      border: 3px dashed #2a7a3e;
      box-shadow: 0 12px 0 #1e4a1e;
    }

    .comic-panels {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      justify-content: center;
    }

    .panel {
      background: white;
      border-radius: 20px;
      padding: 20px 15px;
      flex: 1 1 180px;
      box-shadow: 6px 6px 0 #4b7b4b;
      border: 2px solid #1e4a1e;
      text-align: center;
    }

    .panel i {
      font-size: 3.5rem;
      color: #1e5e2a;
      margin-bottom: 10px;
    }

    .panel h4 {
      font-weight: 700;
      margin-bottom: 8px;
    }

    .balao {
      background: #fff9e0;
      border-radius: 16px 16px 16px 4px;
      padding: 12px;
      font-size: 0.95rem;
      border: 1px solid #bbb;
    }

    /* soluções */
    .solucoes-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 25px;
      margin-top: 30px;
    }

    .sol-card {
      background: white;
      border-radius: 24px;
      padding: 25px;
      box-shadow: 0 5px 15px rgba(0,20,0,0.05);
      border-top: 6px solid #3c9b4b;
    }

    .sol-card i {
      font-size: 2.2rem;
      background: #e1f3d8;
      padding: 12px;
      border-radius: 18px;
      margin-bottom: 20px;
    }

    /* mini game */
    .game-area {
      background: #1a3b1a;
      border-radius: 30px;
      padding: 30px;
      color: white;
      box-shadow: inset 0 0 0 2px #7fb07f, 0 20px 25px -5px rgba(0,0,0,0.3);
    }

    .game-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }

    .game-stats {
      font-weight: 600;
      background: #0f260f;
      padding: 8px 20px;
      border-radius: 40px;
    }

    .game-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 15px;
      margin: 25px 0;
    }

    .card-game {
      aspect-ratio: 1/1;
      background: #e2f0d9;
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.6rem;
      cursor: pointer;
      transition: 0.15s;
      box-shadow: 0 8px 0 #0b1e0b;
      border: 2px solid #aacf9e;
      color: #1a4f1a;
    }
    
    /* Correção: Cartas combinadas não devem ter deslocamento para manter layout alinhado */
    .card-game.matched {
      background: #cbe6c1;
      box-shadow: 0 8px 0 #0b1e0b;
      transform: translateY(0);
      cursor: default;
      opacity: 0.8;
    }
    
    .card-game.flipped {
      background: #cbe6c1;
      box-shadow: 0 4px 0 #0b1e0b;
      transform: translateY(4px);
    }

    .game-btn {
      background: #f4b942;
      border: none;
      font-weight: 700;
      padding: 14px 28px;
      border-radius: 50px;
      font-size: 1.2rem;
      color: #1e3a1e;
      cursor: pointer;
      box-shadow: 0 6px 0 #b57f1a;
      transition: 0.1s;
    }

    .game-btn:active {
      transform: translateY(4px);
      box-shadow: 0 2px 0 #b57f1a;
    }

    footer {
      background: #0a2b12;
      color: #d4e8ca;
      padding: 30px 0;
      text-align: center;
    }

    @media (max-width: 700px) {
      .header-flex {
        flex-direction: column;
        gap: 15px;
      }
      nav ul {
        gap: 15px;
        flex-wrap: wrap;
        justify-content: center;
      }
      .grid-2col {
        grid-template-columns: 1fr;
      }
      .hero h2 {
        font-size: 2.2rem;
      }
    }
  </style>
</head>
<body>
